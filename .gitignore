# Python environment
.venv/

# Build scripts (instructor-only). Both legacy (no underscore) and the
# leading-underscore convention used from MP3 onward.
MP*/build_notebook.py
MP*/**/_*.py

# Built RAG indexes (regenerated at runtime by the build scripts)
chroma_db/

# MCP server runtime logs
MP*/**/logs/

# Spec documents (hidden until after assignment due dates)
specs/

# Grading — confidential student work, evaluations, and grades
grading/

# Claude Code config (instructor-only)
.claude/

# Jupyter
.ipynb_checkpoints/
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db

# Secrets — never commit
.env

# Slides — distributed via Canvas
*.pptx
~$*.pptx

# Module 2 in-class instructor tooling
Module_2_in_class/node_modules/
Module_2_in_class/render_*/
Module_2_in_class/package*.json
Module_2_in_class/*.js
Module_2_in_class/render_slides.py
Module_2_in_class/qa_deck.py
Module_2_in_class/session5_instructor_notes.md

# Module 3 in-class instructor tooling
Module_3_in_class/node_modules/
Module_3_in_class/render_*/
Module_3_in_class/package*.json
Module_3_in_class/*.js
Module_3_in_class/render_slides.py
Module_3_in_class/qa_deck.py
Module_3_in_class/**/*_instructor_notes.md
Module_3_in_class/**/node_modules/
Module_3_in_class/**/package*.json

# Module 4 in-class instructor tooling
Module_4_in_class/node_modules/
Module_4_in_class/render_*/
Module_4_in_class/package*.json
